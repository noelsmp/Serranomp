@page "/passwort-neu-setzen"
@layout AuthLayout
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject AppDbContext Db

<PageTitle>Neues Passwort setzen – Patientenportal</PageTitle>

<h2>Neues Passwort setzen</h2>

@if (tokenUngueltig)
{
    <div class="alert alert-error">
        <strong>Link ungültig oder abgelaufen.</strong>
        <p>Dieser Link ist nicht mehr gültig. Bitte fordern Sie einen neuen Link an.</p>
    </div>
    <div class="auth-links">
        <a href="/passwort-vergessen">Neuen Link anfordern</a>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(fehler))
    {
        <div class="alert alert-error">@fehler</div>
    }

    <form method="post" @formname="passwort-neu-setzen">
        <AntiforgeryToken />
        <input type="hidden" name="Input.Token" value="@TokenQuery" />
        <div class="form-group">
            <label for="passwort">Neues Passwort</label>
            <input id="passwort" type="password" name="Input.Passwort"
                   class="form-control" required autocomplete="new-password" />
            <small class="form-hint">Mindestens 8 Zeichen, 1 Großbuchstabe, 1 Ziffer</small>
        </div>
        <div class="form-group">
            <label for="passwort2">Passwort bestätigen</label>
            <input id="passwort2" type="password" name="Input.Passwort2"
                   class="form-control" required autocomplete="new-password" />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Passwort speichern</button>
    </form>
}

@code {
    [SupplyParameterFromForm]
    private PasswortNeuSetzenInput Input { get; set; } = new();

    [SupplyParameterFromQuery(Name = "token")]
    private string? TokenQuery { get; set; }

    private bool tokenUngueltig;
    private string? fehler;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext == null) return;

        if (httpContext.Request.Method == "GET")
        {
            // Validate the token on GET
            if (string.IsNullOrWhiteSpace(TokenQuery))
            {
                tokenUngueltig = true;
                return;
            }
            var token = Db.PasswortResetTokens.FirstOrDefault(t => t.Token == TokenQuery);
            if (token == null || token.Ablauf < DateTime.UtcNow)
                tokenUngueltig = true;
        }
        else if (httpContext.Request.Method == "POST")
        {
            await HandlePasswortNeuSetzen();
        }
    }

    private async Task HandlePasswortNeuSetzen()
    {
        var tokenStr = Input.Token ?? TokenQuery;
        if (string.IsNullOrWhiteSpace(tokenStr))
        {
            tokenUngueltig = true;
            return;
        }

        var resetToken = Db.PasswortResetTokens.FirstOrDefault(t => t.Token == tokenStr);
        if (resetToken == null || resetToken.Ablauf < DateTime.UtcNow)
        {
            tokenUngueltig = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(Input.Passwort) || Input.Passwort.Length < 8)
        {
            fehler = "Das Passwort muss mindestens 8 Zeichen lang sein.";
            return;
        }
        if (!Input.Passwort.Any(char.IsUpper))
        {
            fehler = "Das Passwort muss mindestens einen Großbuchstaben enthalten.";
            return;
        }
        if (!Input.Passwort.Any(char.IsDigit))
        {
            fehler = "Das Passwort muss mindestens eine Ziffer enthalten.";
            return;
        }
        if (Input.Passwort != Input.Passwort2)
        {
            fehler = "Die Passwörter stimmen nicht überein.";
            return;
        }

        var benutzer = await Db.Benutzer.FindAsync(resetToken.UserId);
        if (benutzer == null)
        {
            tokenUngueltig = true;
            return;
        }

        benutzer.PasswortHash = BCrypt.Net.BCrypt.HashPassword(Input.Passwort, 12);
        Db.PasswortResetTokens.Remove(resetToken);
        await Db.SaveChangesAsync();

        Navigation.NavigateTo("/login?passwort-geaendert=1", forceLoad: true);
    }

    private class PasswortNeuSetzenInput
    {
        public string? Token { get; set; }
        public string Passwort { get; set; } = string.Empty;
        public string Passwort2 { get; set; } = string.Empty;
    }
}
