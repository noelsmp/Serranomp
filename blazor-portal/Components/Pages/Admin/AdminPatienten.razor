@page "/admin/patienten"
@rendermode InteractiveServer
@layout PortalLayout
@attribute [Authorize(Roles = "admin")]
@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>Patienten – Admin</PageTitle>

<div class="page-header">
    <h1>Patienten</h1>
    <div class="page-header-actions">
        <span class="text-muted">@gefiltertePatienten.Count von @allePatienten.Count Patienten</span>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="search-bar">
            <input type="text" class="form-control" placeholder="Suche nach Name, E-Mail oder Patienten-Nr..."
                   value="@suchbegriff" @oninput="e => { suchbegriff = e.Value?.ToString() ?? string.Empty; FilterPatienten(); }" />
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (gefiltertePatienten.Count == 0)
        {
            <p class="text-muted">Keine Patienten gefunden.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>E-Mail</th>
                            <th>Patienten-Nr.</th>
                            <th>Status</th>
                            <th>Registriert</th>
                            <th>Letzter Login</th>
                            <th>Aktion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in gefiltertePatienten)
                        {
                            <tr>
                                <td>@p.Vorname @p.Nachname</td>
                                <td>@p.Email</td>
                                <td>@(p.PraxisPatientNr ?? "–")</td>
                                <td>
                                    <span class="badge @(p.Status == "aktiv" ? "badge-success" : "badge-error")">
                                        @p.Status
                                    </span>
                                </td>
                                <td>@p.Erstellt.ToString("dd.MM.yyyy")</td>
                                <td>@(p.LetzterLogin?.ToString("dd.MM.yyyy HH:mm") ?? "Noch nie")</td>
                                <td>
                                    <a href="/admin/patienten/@p.Id" class="btn btn-sm btn-outline">
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Data.Models.Benutzer> allePatienten = new();
    private List<Data.Models.Benutzer> gefiltertePatienten = new();
    private string suchbegriff = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        allePatienten = await System.Threading.Tasks.Task.Run(() =>
            Db.Benutzer
                .Where(b => b.Rolle == "patient")
                .OrderBy(b => b.Nachname)
                .ThenBy(b => b.Vorname)
                .ToList());
        gefiltertePatienten = allePatienten;
    }

    private void FilterPatienten()
    {
        if (string.IsNullOrWhiteSpace(suchbegriff))
        {
            gefiltertePatienten = allePatienten;
        }
        else
        {
            var s = suchbegriff.ToLower().Trim();
            gefiltertePatienten = allePatienten.Where(p =>
                p.Vorname.ToLower().Contains(s) ||
                p.Nachname.ToLower().Contains(s) ||
                p.Email.ToLower().Contains(s) ||
                (p.PraxisPatientNr != null && p.PraxisPatientNr.ToLower().Contains(s))
            ).ToList();
        }
    }
}
