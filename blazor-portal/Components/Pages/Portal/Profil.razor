@page "/profil"
@rendermode InteractiveServer
@layout PortalLayout
@attribute [Authorize]
@inject AppDbContext Db

<PageTitle>Mein Profil – Patientenportal</PageTitle>

<div class="page-header">
    <h1>Mein Profil</h1>
</div>

@if (benutzer != null)
{
    <div class="grid-2col">
        <div class="card">
            <div class="card-header">
                <h2>Persönliche Daten</h2>
            </div>
            <div class="card-body">
                <dl class="info-list">
                    <dt>Name</dt>
                    <dd>@benutzer.Vorname @benutzer.Nachname</dd>
                    <dt>E-Mail</dt>
                    <dd>@benutzer.Email</dd>
                    @if (benutzer.Geburtsdatum.HasValue)
                    {
                        <dt>Geburtsdatum</dt>
                        <dd>@benutzer.Geburtsdatum.Value.ToString("dd.MM.yyyy")</dd>
                    }
                    @if (!string.IsNullOrEmpty(benutzer.Telefon))
                    {
                        <dt>Telefon</dt>
                        <dd>@benutzer.Telefon</dd>
                    }
                    @if (!string.IsNullOrEmpty(benutzer.PraxisPatientNr))
                    {
                        <dt>Patienten-Nr.</dt>
                        <dd>@benutzer.PraxisPatientNr</dd>
                    }
                    <dt>Registriert seit</dt>
                    <dd>@benutzer.Erstellt.ToString("dd.MM.yyyy")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Passwort ändern</h2>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(passwortErfolg))
                {
                    <div class="alert alert-success">@passwortErfolg</div>
                }
                @if (!string.IsNullOrEmpty(passwortFehler))
                {
                    <div class="alert alert-error">@passwortFehler</div>
                }

                <div class="form-group">
                    <label>Aktuelles Passwort</label>
                    <input type="password" class="form-control" @bind="altesPasswort" autocomplete="current-password" />
                </div>
                <div class="form-group">
                    <label>Neues Passwort</label>
                    <input type="password" class="form-control" @bind="neuesPasswort" autocomplete="new-password" />
                    <small class="form-hint">Mindestens 8 Zeichen, 1 Großbuchstabe, 1 Ziffer</small>
                </div>
                <div class="form-group">
                    <label>Neues Passwort bestätigen</label>
                    <input type="password" class="form-control" @bind="neuesPasswort2" autocomplete="new-password" />
                </div>
                <button class="btn btn-primary" @onclick="PasswortAendern">Passwort ändern</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string? userId;
    private Benutzer? benutzer;
    private string altesPasswort = string.Empty;
    private string neuesPasswort = string.Empty;
    private string neuesPasswort2 = string.Empty;
    private string? passwortErfolg;
    private string? passwortFehler;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId != null)
            benutzer = await Db.Benutzer.FindAsync(userId);
    }

    private async Task PasswortAendern()
    {
        passwortErfolg = null;
        passwortFehler = null;

        if (benutzer == null) return;

        if (string.IsNullOrWhiteSpace(altesPasswort))
        {
            passwortFehler = "Bitte aktuelles Passwort eingeben.";
            return;
        }
        if (!BCrypt.Net.BCrypt.Verify(altesPasswort, benutzer.PasswortHash))
        {
            passwortFehler = "Das aktuelle Passwort ist falsch.";
            return;
        }
        if (string.IsNullOrWhiteSpace(neuesPasswort) || neuesPasswort.Length < 8)
        {
            passwortFehler = "Das neue Passwort muss mindestens 8 Zeichen lang sein.";
            return;
        }
        if (!neuesPasswort.Any(char.IsUpper))
        {
            passwortFehler = "Das neue Passwort muss mindestens einen Großbuchstaben enthalten.";
            return;
        }
        if (!neuesPasswort.Any(char.IsDigit))
        {
            passwortFehler = "Das neue Passwort muss mindestens eine Ziffer enthalten.";
            return;
        }
        if (neuesPasswort != neuesPasswort2)
        {
            passwortFehler = "Die neuen Passwörter stimmen nicht überein.";
            return;
        }

        benutzer.PasswortHash = BCrypt.Net.BCrypt.HashPassword(neuesPasswort, 12);
        await Db.SaveChangesAsync();

        altesPasswort = string.Empty;
        neuesPasswort = string.Empty;
        neuesPasswort2 = string.Empty;
        passwortErfolg = "Passwort erfolgreich geändert.";
    }
}
