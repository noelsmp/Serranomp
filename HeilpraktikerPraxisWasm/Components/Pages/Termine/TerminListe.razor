@page "/termine"
@inject TerminService TerminSvc
@inject EmailService EmailSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Termine</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">Terminkalender</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Info"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => Nav.NavigateTo("/termine/neu"))">
        Neuer Termin
    </MudButton>
</MudStack>

<!-- Kalender-Navigation -->
<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="VorherigeWoche" />
            <MudText Typo="Typo.subtitle1">
                @_wochenStart.ToString("dd.MM.") – @_wochenStart.AddDays(6).ToString("dd.MM.yyyy")
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NaechsteWoche" />
            <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="Heute">Heute</MudButton>
        </MudStack>
    </MudCardContent>
</MudCard>

<!-- Wochenansicht -->
<MudGrid Spacing="2">
    @for (int i = 0; i < 7; i++)
    {
        var tag = _wochenStart.AddDays(i);
        var tagTermine = _termine.Where(t => t.Datum.Date == tag.Date).OrderBy(t => t.Datum).ToList();
        var istHeute = tag.Date == DateTime.Today;

        <MudItem xs="12" sm="6">
            <MudCard Elevation="@(istHeute ? 4 : 1)"
                     Style="@(istHeute ? "border: 2px solid #15803d;" : "")">
                <MudCardHeader Class="pb-1">
                    <CardHeaderContent>
                        <MudText Typo="Typo.body2" Color="@(istHeute ? Color.Success : Color.Default)">
                            <b>@tag.ToString("ddd", new System.Globalization.CultureInfo("de-DE"))</b>
                        </MudText>
                        <MudText Typo="Typo.h6" Color="@(istHeute ? Color.Success : Color.Default)">
                            @tag.Day
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/termine/neu?datum={tag:yyyy-MM-dd}"))" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-2" Style="min-height:120px">
                    @foreach (var t in tagTermine)
                    {
                        <MudPaper Class="pa-2 mb-1 cursor-pointer"
                                  Style="@GetTerminStyle(t)"
                                  @onclick="@(() => Nav.NavigateTo($"/termine/{t.Id}"))">
                            <MudText Typo="Typo.caption"><b>@t.Datum.ToString("HH:mm")</b></MudText>
                            <MudText Typo="Typo.caption">@(t.Patient?.VollerName ?? "–")</MudText>
                            <MudText Typo="Typo.caption" Style="opacity:0.8">@t.Art</MudText>
                        </MudPaper>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

<!-- Liste -->
<MudCard Elevation="2" Class="mt-4">
    <MudCardHeader>
        <CardHeaderContent><MudText Typo="Typo.subtitle1">Alle Termine dieser Woche</MudText></CardHeaderContent>
    </MudCardHeader>
    <MudTable T="Termin" Items="@_termine" Dense="true" Hover="true"
              OnRowClick="@(args => Nav.NavigateTo($"/termine/{args.Item.Id}"))">
        <HeaderContent>
            <MudTh>Datum & Zeit</MudTh>
            <MudTh>Patient</MudTh>
            <MudTh>Behandlungsart</MudTh>
            <MudTh>Dauer</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate Context="t">
            <MudTd>@t.Datum.ToString("dd.MM.yyyy HH:mm")</MudTd>
            <MudTd>@(t.Patient?.VollerName ?? "–")</MudTd>
            <MudTd>@t.Art</MudTd>
            <MudTd>@t.DauerMinuten Min.</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(t.Status)">
                    @GetStatusText(t.Status)
                </MudChip>
            </MudTd>
            <MudTd>
                <MudStack Row="true">
                    <div @onclick:stopPropagation>
                        <MudTooltip Text="Per E-Mail senden">
                            <MudIconButton Icon="@Icons.Material.Filled.Email" Size="Size.Small" Color="Color.Primary"
                                           Disabled="@string.IsNullOrEmpty(t.Patient?.Email)"
                                           OnClick="@(() => MailDialogOeffnen(t))" />
                        </MudTooltip>
                    </div>
                    <div @onclick:stopPropagation>
                        <MudTooltip Text="Per SMS senden">
                            <MudIconButton Icon="@Icons.Material.Filled.Sms" Size="Size.Small" Color="Color.Secondary"
                                           Disabled="@string.IsNullOrEmpty(t.Patient?.Telefon)"
                                           OnClick="@(() => SmsSenden(t))" />
                        </MudTooltip>
                    </div>
                    <div @onclick:stopPropagation>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => Nav.NavigateTo($"/termine/{t.Id}/bearbeiten"))" />
                    </div>
                    <div @onclick:stopPropagation>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => LoeschenAsync(t.Id))" />
                    </div>
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudCard>

<!-- Mail-Dialog -->
<MudDialog @bind-Visible="_mailDialog">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Terminbestätigung per E-Mail</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_mailFehler != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_mailFehler</MudAlert>
        }
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Termin: <b>@_mailTermin?.Datum.ToString("dd.MM.yyyy HH:mm")</b> · @_mailTermin?.Art
                </MudText>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_mailEmpfaenger" Label="E-Mail Empfänger"
                              Variant="Variant.Outlined" InputType="InputType.Email"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            </MudItem>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Dense="true">
                    Der Patient erhält eine Terminbestätigung mit Datum, Uhrzeit und Praxisadresse.
                </MudAlert>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { _mailDialog = false; _mailFehler = null; })">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Send"
                   Disabled="@(_mailSending || string.IsNullOrWhiteSpace(_mailEmpfaenger))"
                   OnClick="MailSenden">
            @(_mailSending ? "Wird gesendet..." : "Senden")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Termin> _termine = [];
    private DateTime _wochenStart = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1);

    private bool _mailDialog;
    private bool _mailSending;
    private string? _mailFehler;
    private string _mailEmpfaenger = "";
    private Termin? _mailTermin;

    protected override async Task OnInitializedAsync() => await Laden();

    private async Task Laden() =>
        _termine = await TerminSvc.AlleTermineAsync(_wochenStart, _wochenStart.AddDays(7));

    private async Task VorherigeWoche() { _wochenStart = _wochenStart.AddDays(-7); await Laden(); }
    private async Task NaechsteWoche() { _wochenStart = _wochenStart.AddDays(7); await Laden(); }
    private async Task Heute() { _wochenStart = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1); await Laden(); }

    private void MailDialogOeffnen(Termin t)
    {
        _mailTermin = t;
        _mailEmpfaenger = t.Patient?.Email ?? "";
        _mailFehler = null;
        _mailDialog = true;
    }

    private async Task MailSenden()
    {
        if (_mailTermin is null || string.IsNullOrWhiteSpace(_mailEmpfaenger)) return;
        _mailSending = true;
        _mailFehler = null;
        try
        {
            await EmailSvc.TerminBestaetigenAsync(_mailTermin, _mailEmpfaenger);
            Snackbar.Add($"Terminbestätigung an {_mailEmpfaenger} gesendet!", Severity.Success);
            _mailDialog = false;
        }
        catch (Exception ex)
        {
            _mailFehler = ex.Message;
        }
        finally
        {
            _mailSending = false;
        }
    }

    private async Task SmsSenden(Termin t)
    {
        if (string.IsNullOrEmpty(t.Patient?.Telefon)) return;
        await EmailSvc.SmsOeffnenAsync(t.Patient.Telefon, t);
    }

    private async Task LoeschenAsync(int id)
    {
        await TerminSvc.LoeschenAsync(id);
        Snackbar.Add("Termin gelöscht.", Severity.Success);
        await Laden();
    }

    private static string GetTerminStyle(Termin t) => t.Status switch
    {
        TerminStatus.Erschienen => "background:#f0fdf4; border-left:3px solid #15803d;",
        TerminStatus.Abgesagt => "background:#fef2f2; border-left:3px solid #ef4444; opacity:0.7;",
        TerminStatus.NichtErschienen => "background:#fff7ed; border-left:3px solid #f59e0b;",
        _ => "background:#eff6ff; border-left:3px solid #3b82f6;"
    };

    private static Color GetStatusColor(TerminStatus s) => s switch
    {
        TerminStatus.Erschienen => Color.Success,
        TerminStatus.Abgesagt => Color.Error,
        TerminStatus.NichtErschienen => Color.Warning,
        _ => Color.Info
    };

    private static string GetStatusText(TerminStatus s) => s switch
    {
        TerminStatus.Erschienen => "Erschienen",
        TerminStatus.Abgesagt => "Abgesagt",
        TerminStatus.NichtErschienen => "Nicht erschienen",
        _ => "Geplant"
    };
}
