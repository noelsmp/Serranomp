# ─── Datenbank (SQLite) ─────────────────────────────────────────────
# Pfad zur SQLite-Datenbank (absolut oder relativ zum Projektverzeichnis)
DB_PATH=/var/data/patientenportal/portal.db

# ─── Datei-Uploads ────────────────────────────────────────────
# Verzeichnis für hochgeladene Dokumente (außerhalb des Web-Root!)
UPLOADS_PATH=/var/data/patientenportal/uploads

# ─── E-Mail via Resend (DSGVO-konform) ───────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=portal@naturheilpraxis-hilfreich.de
EMAIL_PRAXIS=info@naturheilpraxis-hilfreich.de
PRAXIS_TELEFON=02841 / 12345

# ─── App-URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://portal.seo-smp.de

# ─── Admin-Setup ───────────────────────────────────────────────
ADMIN_EMAIL=info@naturheilpraxis-hilfreich.de
ADMIN_INITIAL_PASSWORD=SicheresPasswort2024!

# ─── Session-Timeout (Sekunden, Standard: 1800 = 30 Minuten) ─────────────
SESSION_TIMEOUT_SECONDS=1800

# ─── Externe REST-API (v1) ──────────────────────────────────────────
# Sicherer Zufallsschlüssel für die externe API (Authorization: Bearer ...)
# Neu generieren mit: openssl rand -hex 32
PORTAL_API_KEY=a7a9cda02df01f55e25086d3102d5fb3c5b300f00081cffeae626bb5685b3b49

# ─── Node-Umgebung ──────────────────────────────────────────────
NODE_ENV=production
